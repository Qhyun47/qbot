{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "URCase",
  "description": "비뇨기과(UR) 환자의 키워드 카드를 정규화한 구조화된 JSON. AI Stage 1 출력 형식.",
  "type": "object",
  "required": [
    "inputs",
    "past_history",
    "medication_history",
    "operation_history"
  ],
  "properties": {
    "inputs": {
      "type": "array",
      "description": "의사가 입력한 키워드 카드 목록. 각 카드는 raw_text, normalized_text, category, sections를 포함.",
      "items": {
        "type": "object",
        "required": ["raw_text", "normalized_text", "category", "sections"],
        "properties": {
          "raw_text": {
            "type": "string",
            "description": "의사가 입력한 원본 텍스트. 절대 수정 금지."
          },
          "normalized_text": {
            "type": "string",
            "description": "AI가 표준 의학 용어로 정규화한 텍스트."
          },
          "category": {
            "type": "string",
            "description": "카드의 임상 분류. 아래 enum 값 중 가장 적합한 것 하나를 선택.",
            "enum": [
              "onset",
              "duration",
              "hematuria",
              "urinary_symptom",
              "voiding_difficulty",
              "scrotal_symptom",
              "flank_pain",
              "npo",
              "associated_symptom",
              "prior_episode",
              "vital_sign",
              "past_history",
              "medication_history",
              "operation_history",
              "npo_status",
              "other"
            ]
          },
          "sections": {
            "type": "array",
            "description": "이 카드가 사용될 섹션 목록. 복수 선택 가능. 카드-섹션 매핑 기준: onset/duration/hematuria/urinary_symptom/voiding_difficulty/scrotal_symptom/flank_pain → [pi, template] | associated_symptom/prior_episode/vital_sign → [pi] | npo → [template] | past_history/medication_history/operation_history → [history] 전용",
            "items": {
              "type": "string",
              "enum": ["pi", "template", "history", "pe"]
            },
            "minItems": 1
          }
        }
      }
    },
    "onset": {
      "type": ["string", "null"],
      "description": "증상 발생 시점 (예: '10.02부터', '금일 오전'). 없으면 null."
    },
    "duration": {
      "type": ["string", "null"],
      "description": "증상 지속 기간 또는 양상 (예: '3일간 지속', '간헐적'). 없으면 null."
    },
    "chief_complaint_category": {
      "type": ["string", "null"],
      "description": "주요 호소 분류.",
      "enum": [
        "hematuria",
        "voiding_difficulty",
        "scrotal_pain",
        "flank_pain",
        "other",
        null
      ]
    },
    "hematuria": {
      "type": ["object", "null"],
      "description": "혈뇨 세부 정보. 없으면 null.",
      "properties": {
        "color": {
          "type": ["string", "null"],
          "description": "혈뇨 색깔 (예: '검붉은색', 'pinkish', '선혈'). 없으면 null."
        },
        "timing": {
          "type": ["string", "null"],
          "description": "배뇨 중 혈뇨 위치 (예: '처음', '중간', '끝', '전체'). 없으면 null."
        },
        "pattern": {
          "type": ["string", "null"],
          "description": "지속적 vs 간헐적 여부. 없으면 null."
        },
        "quantity": {
          "type": ["string", "null"],
          "description": "혈뇨 양 서술 (예: '소주잔 1-2잔 분량'). 없으면 null."
        }
      }
    },
    "urinary_symptoms": {
      "type": ["object", "null"],
      "description": "비뇨기 증상 체크. 없으면 null.",
      "properties": {
        "frequency": {
          "type": ["boolean", "null"],
          "description": "빈뇨"
        },
        "urgency": {
          "type": ["boolean", "null"],
          "description": "절박뇨"
        },
        "nocturia": {
          "type": ["boolean", "null"],
          "description": "야간뇨"
        },
        "dysuria": {
          "type": ["boolean", "null"],
          "description": "배뇨통"
        }
      }
    },
    "voiding_difficulty": {
      "type": ["object", "null"],
      "description": "배뇨곤란 세부 정보. 없으면 null.",
      "properties": {
        "onset_time": {
          "type": ["string", "null"],
          "description": "배뇨곤란 시작 시각."
        },
        "last_void": {
          "type": ["string", "null"],
          "description": "마지막 소변 시각."
        },
        "foley_initial_urine": {
          "type": ["string", "null"],
          "description": "Foley 삽입 후 initial urine 양."
        }
      }
    },
    "scrotal_symptoms": {
      "type": ["object", "null"],
      "description": "음낭/고환 증상. 없으면 null.",
      "properties": {
        "pain": {
          "type": ["boolean", "null"]
        },
        "swelling": {
          "type": ["boolean", "null"]
        },
        "redness": {
          "type": ["boolean", "null"]
        },
        "tenderness": {
          "type": ["boolean", "null"]
        },
        "cremasteric_reflex": {
          "type": ["boolean", "null"],
          "description": "정상이면 true(+), 소실이면 false(-)."
        },
        "prehn_sign": {
          "type": ["boolean", "null"],
          "description": "음낭 거상 시 통증완화되면 true(+)."
        },
        "transillumination": {
          "type": ["boolean", "null"],
          "description": "빛이 음낭을 통과하면 true(+)."
        }
      }
    },
    "cvat": {
      "type": ["string", "null"],
      "description": "늑골척추각 압통 여부 및 측면 (예: 'Lt.', 'Rt.', 'both', '(-)'). 없으면 null."
    },
    "npo": {
      "type": ["object", "null"],
      "description": "금식 시작 시각. 없으면 null.",
      "properties": {
        "solid": {
          "type": ["string", "null"],
          "description": "고형식 금식 시작 시각."
        },
        "liquid": {
          "type": ["string", "null"],
          "description": "수분 금식 시작 시각."
        }
      }
    },
    "associated_symptoms": {
      "type": ["array", "null"],
      "description": "동반 증상 목록. 없으면 null.",
      "items": {
        "type": "string"
      }
    },
    "prior_episode": {
      "type": ["string", "null"],
      "description": "유사 증상 과거 에피소드. 없으면 null."
    },
    "past_history": {
      "type": ["array", "null"],
      "description": "과거력 목록. History 출력 시 항상 포함; 내용 없으면 null → 공란.",
      "items": {
        "type": "string"
      }
    },
    "medication_history": {
      "type": ["array", "null"],
      "description": "복용 약물 목록. History 출력 시 항상 포함; 내용 없으면 null → 공란.",
      "items": {
        "type": "string"
      }
    },
    "operation_history": {
      "type": ["array", "null"],
      "description": "수술력 목록. History 출력 시 항상 포함; 내용 없으면 null → 공란.",
      "items": {
        "type": "string"
      }
    },
    "npo_solid": {
      "type": ["string", "null"],
      "description": "마지막 고형식 섭취 시점 (MM.DD HH:mm 형식). '|' 뒤에 추가 정보 포함 가능. 없으면 null."
    },
    "npo_liquid": {
      "type": ["string", "null"],
      "description": "마지막 수분 섭취 시점 (MM.DD HH:mm 형식). '|' 뒤에 추가 정보 포함 가능. 없으면 null."
    }
  }
}
