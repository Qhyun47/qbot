{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IMBasicCase",
  "description": "내과 기본(General weakness / Fever / Abnormal lab 등) 환자의 키워드 카드를 정규화한 구조화된 JSON. AI Stage 1 출력 형식.",
  "type": "object",
  "required": [
    "inputs",
    "past_history",
    "medication_history",
    "operation_history",
    "family_history"
  ],
  "properties": {
    "inputs": {
      "type": "array",
      "description": "의사가 입력한 키워드 카드 목록. 각 카드는 raw_text, normalized_text, category, sections를 포함.",
      "items": {
        "type": "object",
        "required": ["raw_text", "normalized_text", "category", "sections"],
        "properties": {
          "raw_text": {
            "type": "string",
            "description": "의사가 입력한 원본 텍스트. 절대 수정 금지."
          },
          "normalized_text": {
            "type": "string",
            "description": "AI가 표준 의학 용어로 정규화한 텍스트."
          },
          "category": {
            "type": "string",
            "description": "카드의 임상 분류. 아래 enum 값 중 가장 적합한 것 하나를 선택.",
            "enum": [
              "onset",
              "duration",
              "chief_complaint",
              "fever",
              "chill",
              "recent_uri",
              "sore_throat",
              "cough",
              "sputum",
              "rhinorrhea",
              "anorexia",
              "nausea",
              "vomiting",
              "diarrhea",
              "constipation",
              "urinary_symptom",
              "gross_hematuria",
              "headache",
              "dizziness",
              "weight_change",
              "npo",
              "associated_symptom",
              "vital_sign",
              "past_history",
              "medication_history",
              "operation_history",
              "family_history",
              "npo_status",
              "other"
            ]
          },
          "sections": {
            "type": "array",
            "description": "이 카드가 사용될 섹션 목록. 복수 선택 가능. 카드-섹션 매핑 기준: onset/duration/chief_complaint/fever/chill/recent_uri/sore_throat/cough/sputum/rhinorrhea/anorexia/nausea/vomiting/diarrhea/constipation/urinary_symptom/gross_hematuria/headache/dizziness/weight_change/associated_symptom → [pi, template] | npo/gas_out/last_defecation/vital_sign → [pi] | past_history/medication_history/operation_history/family_history → [history] 전용 (HPI·상용구에 포함 금지)",
            "items": {
              "type": "string",
              "enum": ["pi", "template", "history", "pe"]
            },
            "minItems": 1
          }
        }
      }
    },
    "onset": {
      "type": ["string", "null"],
      "description": "증상 발생 시점 (예: '3일 전', '1주일 전', '금일 오전'). 없으면 null."
    },
    "duration": {
      "type": ["string", "null"],
      "description": "증상 지속 기간 또는 경과 양상 (예: '3일간 지속', '간헐적으로 2주'). 없으면 null."
    },
    "chief_complaint_detail": {
      "type": ["string", "null"],
      "description": "주 증상의 구체적 설명 (예: '전신 쇠약감 심화', '38.5도 발열'). 없으면 null."
    },
    "fever": {
      "type": ["boolean", "null"],
      "description": "발열 여부. true/false/null."
    },
    "chill": {
      "type": ["boolean", "null"],
      "description": "오한 여부. true/false/null."
    },
    "recent_uri": {
      "type": ["boolean", "null"],
      "description": "최근 상기도감염 여부. true/false/null."
    },
    "sore_throat": {
      "type": ["boolean", "null"],
      "description": "인후통 여부. true/false/null."
    },
    "cough": {
      "type": ["boolean", "null"],
      "description": "기침 여부. true/false/null."
    },
    "sputum": {
      "type": ["boolean", "null"],
      "description": "가래 여부. true/false/null."
    },
    "rhinorrhea": {
      "type": ["boolean", "null"],
      "description": "콧물 여부. true/false/null."
    },
    "anorexia": {
      "type": ["boolean", "null"],
      "description": "식욕부진 여부. true/false/null."
    },
    "nausea": {
      "type": ["boolean", "null"],
      "description": "구역 여부. true/false/null."
    },
    "vomiting": {
      "type": ["boolean", "null"],
      "description": "구토 여부. true/false/null."
    },
    "diarrhea": {
      "type": ["boolean", "null"],
      "description": "설사 여부. true/false/null."
    },
    "constipation": {
      "type": ["boolean", "null"],
      "description": "변비 여부. true/false/null."
    },
    "urinary_frequency": {
      "type": ["boolean", "null"],
      "description": "빈뇨 여부. true/false/null."
    },
    "urinary_urgency": {
      "type": ["boolean", "null"],
      "description": "절박뇨 여부. true/false/null."
    },
    "nocturia": {
      "type": ["boolean", "null"],
      "description": "야간뇨 여부. true/false/null."
    },
    "dysuria": {
      "type": ["boolean", "null"],
      "description": "배뇨통 여부. true/false/null."
    },
    "gross_hematuria": {
      "type": ["boolean", "null"],
      "description": "육안적 혈뇨 여부. true/false/null."
    },
    "headache": {
      "type": ["boolean", "null"],
      "description": "두통 여부. true/false/null."
    },
    "dizziness": {
      "type": ["boolean", "null"],
      "description": "어지러움 여부. true/false/null."
    },
    "weight_change": {
      "type": ["string", "null"],
      "description": "체중 변화 표현 (예: '3kg 감소/1개월', '체중 증가'). 없으면 null."
    },
    "npo": {
      "type": ["string", "null"],
      "description": "금식 여부 및 시작 시점 (예: '금일 오전부터', '12시간 이상'). 없으면 null."
    },
    "gas_out": {
      "type": ["boolean", "null"],
      "description": "가스 배출 여부. true/false/null."
    },
    "last_defecation": {
      "type": ["string", "null"],
      "description": "마지막 배변 시점 (예: '2일 전', '금일 오전'). 없으면 null."
    },
    "associated_symptoms": {
      "type": ["array", "null"],
      "description": "위 분류에 속하지 않는 기타 동반 증상 목록 (예: dyspnea, palpitation, chest pain 등). 없으면 null.",
      "items": {
        "type": "string"
      }
    },
    "past_history": {
      "type": ["array", "null"],
      "description": "과거력 목록 (예: ['고혈압', '당뇨', '간경화']). History 출력 시 항상 포함; 내용 없으면 null → (-)로 출력.",
      "items": {
        "type": "string"
      }
    },
    "medication_history": {
      "type": ["array", "null"],
      "description": "복용 약물 목록 (예: ['metformin', 'amlodipine']). History 출력 시 항상 포함; 내용 없으면 null → (-)로 출력.",
      "items": {
        "type": "string"
      }
    },
    "operation_history": {
      "type": ["array", "null"],
      "description": "수술력 목록 (예: ['LC 2020년', '충수절제술']). History 출력 시 항상 포함; 내용 없으면 null → (-)로 출력.",
      "items": {
        "type": "string"
      }
    },
    "family_history": {
      "type": ["array", "null"],
      "description": "가족력 목록 (예: ['부: 고혈압', '모: 당뇨']). null이면 History 출력 시 해당 항목 전체 생략.",
      "items": {
        "type": "string"
      }
    },
    "npo_solid": {
      "type": ["string", "null"],
      "description": "마지막 고형식 섭취 시점 (MM.DD HH:mm 형식). '|' 뒤에 추가 정보 포함 가능. 없으면 null."
    },
    "npo_liquid": {
      "type": ["string", "null"],
      "description": "마지막 수분 섭취 시점 (MM.DD HH:mm 형식). '|' 뒤에 추가 정보 포함 가능. 없으면 null."
    }
  }
}
