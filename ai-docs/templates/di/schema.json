{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DrugIntoxicationCase",
  "description": "Drug intoxication / Drug overdose 환자의 키워드 카드를 정규화한 구조화된 JSON. AI Stage 1 출력 형식.",
  "type": "object",
  "required": ["inputs", "past_history", "medication_history", "pc_history"],
  "properties": {
    "inputs": {
      "type": "array",
      "description": "의사가 입력한 키워드 카드 목록. 각 카드는 raw_text, normalized_text, category, sections를 포함.",
      "items": {
        "type": "object",
        "required": ["raw_text", "normalized_text", "category", "sections"],
        "properties": {
          "raw_text": {
            "type": "string",
            "description": "의사가 입력한 원본 텍스트. 절대 수정 금지."
          },
          "normalized_text": {
            "type": "string",
            "description": "AI가 표준 의학 용어로 정규화한 텍스트."
          },
          "category": {
            "type": "string",
            "description": "카드의 임상 분류.",
            "enum": [
              "substance",
              "amount",
              "ingestion_time",
              "reason_motive",
              "obtain_route",
              "discovery_to_arrival",
              "consciousness_at_discovery",
              "vomiting_before_arrival",
              "co_specific",
              "interview_ready",
              "incident_content",
              "incident_process",
              "duration",
              "hallucination",
              "suicide_thinking_attempt",
              "recent_stress",
              "social_history",
              "past_history",
              "medication_history",
              "pc_history",
              "vital_sign",
              "npo_status",
              "other"
            ]
          },
          "sections": {
            "type": "array",
            "description": "이 카드가 사용될 섹션 목록. 복수 선택 가능.",
            "items": {
              "type": "string",
              "enum": ["pi", "template", "history", "pe"]
            },
            "minItems": 1
          }
        }
      }
    },
    "interview_ready": {
      "type": ["string", "null"],
      "description": "환자 면담 협조 가능 여부. 없으면 null."
    },
    "substance": {
      "type": ["string", "null"],
      "description": "복용한 물질 이름 (예: '수면제', '아세트아미노펜', 'CO'). 없으면 null."
    },
    "amount": {
      "type": ["string", "null"],
      "description": "복용량 (예: '10알', '불명'). 없으면 null."
    },
    "ingestion_time": {
      "type": ["string", "null"],
      "description": "복용 시각 또는 시점. 없으면 null."
    },
    "reason_motive": {
      "type": ["string", "null"],
      "description": "복용 이유 및 동기. 없으면 null."
    },
    "obtain_route": {
      "type": ["string", "null"],
      "description": "약을 구한 경로. 없으면 null."
    },
    "discovery_to_arrival": {
      "type": ["string", "null"],
      "description": "발견부터 내원까지 경과. 없으면 null."
    },
    "consciousness_at_discovery": {
      "type": ["string", "null"],
      "description": "발견 당시 의식 수준. 없으면 null."
    },
    "vomiting_before_arrival": {
      "type": ["string", "null"],
      "description": "내원 전 구토 여부 및 횟수. 없으면 null."
    },
    "co_poisoning": {
      "type": ["object", "null"],
      "description": "CO 중독 관련 정보. CO 중독이 아니면 null.",
      "properties": {
        "co_hb": {
          "type": ["string", "null"],
          "description": "Initial ABGA CO Hb 수치 (예: '25%'). 없으면 null."
        },
        "fire_start_time": {
          "type": ["string", "null"],
          "description": "불을 붙인 시간. 없으면 null."
        },
        "enclosed_space": {
          "type": ["boolean", "null"],
          "description": "밀폐 공간 여부. true/false/null."
        },
        "combustion_degree": {
          "type": ["string", "null"],
          "description": "연소 정도 (예: '조금 탐', '전소'). 없으면 null."
        },
        "report_time": {
          "type": ["string", "null"],
          "description": "신고 시간. 없으면 null."
        },
        "ems_arrival_time": {
          "type": ["string", "null"],
          "description": "119 도착 시간. 없으면 null."
        },
        "o2_transport": {
          "type": ["string", "null"],
          "description": "이송 중 O2 공급 방식 (예: 'O2 full mask', 'room air'). 없으면 null."
        },
        "loc": {
          "type": ["boolean", "null"],
          "description": "LOC 여부. true/false/null."
        }
      }
    },
    "pc_section": {
      "type": ["object", "null"],
      "description": "정신건강의학과 관련 정보.",
      "properties": {
        "incident_content": {
          "type": ["string", "null"],
          "description": "사고 내용. 없으면 null."
        },
        "incident_process": {
          "type": ["string", "null"],
          "description": "사고 경위 및 과정. 없으면 null."
        },
        "duration": {
          "type": ["string", "null"],
          "description": "증상 지속 기간. 없으면 null."
        },
        "auditory_hallucination": {
          "type": ["boolean", "null"],
          "description": "환청 여부. true/false/null."
        },
        "visual_hallucination": {
          "type": ["boolean", "null"],
          "description": "환시 여부. true/false/null."
        },
        "suicide_thinking": {
          "type": ["boolean", "null"],
          "description": "자살 사고 여부. true/false/null."
        },
        "suicide_attempt": {
          "type": ["boolean", "null"],
          "description": "자살 시도 여부. true/false/null."
        },
        "recent_stress": {
          "type": ["string", "null"],
          "description": "최근 스트레스 요인. 없으면 null."
        },
        "personality": {
          "type": ["string", "null"],
          "description": "성격 기술. 없으면 null."
        },
        "occupation": {
          "type": ["string", "null"],
          "description": "직업. 없으면 null."
        },
        "marital_status": {
          "type": ["string", "null"],
          "description": "결혼 여부 (예: '기혼', '미혼', '이혼'). 없으면 null."
        },
        "education": {
          "type": ["string", "null"],
          "description": "학력. 없으면 null."
        },
        "economic_status": {
          "type": ["string", "null"],
          "description": "경제 상황. 없으면 null."
        },
        "family_relation": {
          "type": ["string", "null"],
          "description": "현재 가족 관계. 없으면 null."
        },
        "religion": {
          "type": ["string", "null"],
          "description": "종교. 없으면 null."
        }
      }
    },
    "past_history": {
      "type": ["array", "null"],
      "description": "과거력 목록. History 출력 시 항상 포함; 내용 없으면 null → (-)로 출력.",
      "items": {
        "type": "string"
      }
    },
    "medication_history": {
      "type": ["array", "null"],
      "description": "복용 약물 목록. History 출력 시 항상 포함; 내용 없으면 null → (-)로 출력.",
      "items": {
        "type": "string"
      }
    },
    "pc_history": {
      "type": ["array", "null"],
      "description": "정신건강의학과 과거력 목록. History 출력 시 항상 포함; 내용 없으면 null → (-)로 출력.",
      "items": {
        "type": "string"
      }
    },
    "npo_solid": {
      "type": ["string", "null"],
      "description": "마지막 고형식 섭취 시점 (MM.DD HH:mm 형식). '|' 뒤에 추가 정보 포함 가능. 없으면 null."
    },
    "npo_liquid": {
      "type": ["string", "null"],
      "description": "마지막 수분 섭취 시점 (MM.DD HH:mm 형식). '|' 뒤에 추가 정보 포함 가능. 없으면 null."
    }
  }
}
