{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FBInNeckCase",
  "description": "목 이물질(Foreign body in neck) 환자의 키워드 카드를 정규화한 구조화된 JSON. AI Stage 1 출력 형식.",
  "type": "object",
  "required": [
    "inputs",
    "past_history",
    "medication_history",
    "operation_history"
  ],
  "properties": {
    "inputs": {
      "type": "array",
      "description": "의사가 입력한 키워드 카드 목록. 각 카드는 raw_text, normalized_text, category, sections를 포함.",
      "items": {
        "type": "object",
        "required": ["raw_text", "normalized_text", "category", "sections"],
        "properties": {
          "raw_text": {
            "type": "string",
            "description": "의사가 입력한 원본 텍스트. 절대 수정 금지."
          },
          "normalized_text": {
            "type": "string",
            "description": "AI가 표준 의학 용어로 정규화한 텍스트."
          },
          "category": {
            "type": "string",
            "description": "카드의 임상 분류. 아래 enum 값 중 가장 적합한 것 하나를 선택.",
            "enum": [
              "fb_type",
              "pain_onset",
              "pain_location",
              "odynophagia",
              "dysphagia",
              "dyspnea",
              "fever_chill",
              "npo",
              "associated_symptom",
              "past_history",
              "medication_history",
              "operation_history",
              "npo_status",
              "other"
            ]
          },
          "sections": {
            "type": "array",
            "description": "이 카드가 사용될 섹션 목록. 카드-섹션 매핑 기준: fb_type/pain_onset/pain_location/odynophagia/dysphagia/dyspnea/fever_chill/npo → [pi, template] | associated_symptom → [pi] | past_history/medication_history/operation_history → [history] 전용",
            "items": {
              "type": "string",
              "enum": ["pi", "template", "history", "pe"]
            },
            "minItems": 1
          }
        }
      }
    },
    "fb_type": {
      "type": ["string", "null"],
      "description": "삼킨 이물질의 종류 (예: '생선 가시', '닭뼈', '동전'). 없으면 null."
    },
    "pain_on_resting": {
      "type": ["boolean", "null"],
      "description": "가만히 있을 때 통증 여부. true/false/null."
    },
    "pain_on_speaking": {
      "type": ["boolean", "null"],
      "description": "말할 때 통증 여부. true/false/null."
    },
    "pain_on_swallowing": {
      "type": ["boolean", "null"],
      "description": "침삼킬 때 통증 여부. true/false/null."
    },
    "pain_location": {
      "type": ["string", "null"],
      "description": "이물질 또는 통증 위치 (예: 'Thyroid cartilage 상방 2cm'). 없으면 null."
    },
    "odynophagia": {
      "type": ["boolean", "null"],
      "description": "연하통 여부. true/false/null."
    },
    "dysphagia": {
      "type": ["boolean", "null"],
      "description": "연하곤란 여부. true/false/null."
    },
    "dyspnea": {
      "type": ["boolean", "null"],
      "description": "호흡곤란 여부. true/false/null."
    },
    "fever": {
      "type": ["boolean", "null"],
      "description": "발열 여부. true/false/null."
    },
    "chilling": {
      "type": ["boolean", "null"],
      "description": "오한 여부. true/false/null."
    },
    "npo_solid": {
      "type": ["string", "null"],
      "description": "마지막 고형식 섭취 시간. 없으면 null."
    },
    "npo_liquid": {
      "type": ["string", "null"],
      "description": "마지막 수분 섭취 시간. 없으면 null."
    },
    "past_history": {
      "type": ["array", "null"],
      "description": "과거력 목록. 없으면 null.",
      "items": {
        "type": "string"
      }
    },
    "medication_history": {
      "type": ["array", "null"],
      "description": "복용 약물 목록. 없으면 null.",
      "items": {
        "type": "string"
      }
    },
    "operation_history": {
      "type": ["array", "null"],
      "description": "수술력 목록. 없으면 null.",
      "items": {
        "type": "string"
      }
    }
  }
}
