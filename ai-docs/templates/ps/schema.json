{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PSCase",
  "description": "PS(성형외과) 협진 환자의 키워드 카드를 정규화한 구조화된 JSON. AI Stage 1 출력 형식.",
  "type": "object",
  "required": [
    "inputs",
    "past_history",
    "medication_history",
    "operation_history",
    "family_history"
  ],
  "properties": {
    "inputs": {
      "type": "array",
      "description": "의사가 입력한 키워드 카드 목록. 각 카드는 raw_text, normalized_text, category, sections를 포함.",
      "items": {
        "type": "object",
        "required": ["raw_text", "normalized_text", "category", "sections"],
        "properties": {
          "raw_text": {
            "type": "string",
            "description": "의사가 입력한 원본 텍스트. 절대 수정 금지."
          },
          "normalized_text": {
            "type": "string",
            "description": "AI가 표준 의학 용어로 정규화한 텍스트."
          },
          "category": {
            "type": "string",
            "description": "카드의 임상 분류. 아래 enum 값 중 가장 적합한 것 하나를 선택.",
            "enum": [
              "onset",
              "mechanism",
              "loc",
              "headache",
              "laceration",
              "abrasion",
              "penetration",
              "associated_symptom",
              "vital_sign",
              "past_history",
              "medication_history",
              "operation_history",
              "family_history",
              "other"
            ]
          },
          "sections": {
            "type": "array",
            "description": "이 카드가 사용될 섹션 목록. 복수 선택 가능. onset/mechanism/loc/headache/laceration/abrasion/penetration → [pi, template] | associated_symptom/vital_sign → [pi] | past_history/medication_history/operation_history/family_history → [history] 전용 (HPI·상용구에 포함 금지)",
            "items": {
              "type": "string",
              "enum": ["pi", "template", "history", "pe"]
            },
            "minItems": 1
          }
        }
      }
    },
    "onset": {
      "type": ["string", "null"],
      "description": "손상 발생 시점 (예: '3시간 전', '금일 오후 3시경'). 없으면 null."
    },
    "mechanism": {
      "type": ["string", "null"],
      "description": "손상 기전 (예: '낙상', '교통사고', '폭행', '자해'). 없으면 null."
    },
    "loc": {
      "type": ["boolean", "null"],
      "description": "의식 소실(LOC) 여부. true/false/null."
    },
    "loc_duration": {
      "type": ["string", "null"],
      "description": "LOC 지속 시간 (예: '수 초', '수 분'). LOC가 없으면 null."
    },
    "headache": {
      "type": ["boolean", "null"],
      "description": "두통 여부. true/false/null."
    },
    "laceration": {
      "type": ["boolean", "null"],
      "description": "열상 여부. true/false/null."
    },
    "laceration_location": {
      "type": ["string", "null"],
      "description": "열상 부위 (예: '이마', '턱', '눈 주위'). 없으면 null."
    },
    "laceration_size": {
      "type": ["string", "null"],
      "description": "열상 크기 (예: '2cm', '약 3cm'). 없으면 null."
    },
    "bone_exposure": {
      "type": ["boolean", "null"],
      "description": "골 노출(bone touch) 여부. true/false/null."
    },
    "active_bleeding": {
      "type": ["boolean", "null"],
      "description": "활동성 출혈 여부. true/false/null."
    },
    "facial_movement_abnormality": {
      "type": ["boolean", "null"],
      "description": "이마 움직임 이상 여부. true/false/null."
    },
    "abrasion": {
      "type": ["boolean", "null"],
      "description": "찰과상 여부. true/false/null."
    },
    "penetration": {
      "type": ["boolean", "null"],
      "description": "관통상 여부. true/false/null."
    },
    "associated_symptoms": {
      "type": ["array", "null"],
      "description": "동반 증상 목록 (예: nausea, vomiting, dizziness 등). 없으면 null.",
      "items": {
        "type": "string"
      }
    },
    "past_history": {
      "type": ["array", "null"],
      "description": "과거력 목록. History 출력 시 항상 포함; 내용 없으면 null → (-)로 출력.",
      "items": {
        "type": "string"
      }
    },
    "medication_history": {
      "type": ["array", "null"],
      "description": "복용 약물 목록. History 출력 시 항상 포함; 내용 없으면 null → (-)로 출력.",
      "items": {
        "type": "string"
      }
    },
    "operation_history": {
      "type": ["array", "null"],
      "description": "수술력 목록. History 출력 시 항상 포함; 내용 없으면 null → (-)로 출력.",
      "items": {
        "type": "string"
      }
    },
    "family_history": {
      "type": ["array", "null"],
      "description": "가족력 목록. null이면 History 출력 시 해당 항목 전체 생략.",
      "items": {
        "type": "string"
      }
    }
  }
}
